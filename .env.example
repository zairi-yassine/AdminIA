# Copier ce fichier en .env et remplir les valeurs

# Provider LLM : "ollama" (local) ou "openrouter" (distant)
LLM_PROVIDER=ollama

# Modèle à utiliser
# Ollama       : mistral | llama3.2 | gemma2:2b
# OpenRouter   : google/gemma-4-31b-it:free
LLM_MODEL=llama3.2

# --- OpenRouter (optionnel, uniquement si LLM_PROVIDER=openrouter) ---
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Ollama (optionnel, valeurs par défaut ci-dessous) ---
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_API_KEY=ollama
